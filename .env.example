# ── LLM Integration ──────────────────────────────────────────────
# Set USE_LLM=true to enable semantic classification, natural-language
# answers, and context-aware clarifications via OpenAI.
USE_LLM=true
OPENAI_API_KEY=sk-...

# Override the default model (gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# ── LangGraph Persistence ─────────────────────────────────────────
# memory (default, no infra), sqlite (file-backed), postgres
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

# ── Human-in-the-Loop ─────────────────────────────────────────────
# Set to true to use real LangGraph interrupt() in approval_node
LANGGRAPH_INTERRUPT=true

# ── Misc ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
